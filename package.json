{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npx esbuild server.ts --bundle --platform=node --packages=external --format=esm --outdir=dist",
    "start": "node dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:start": "npm run build && electron .",
    "build:exe": "npm run build && electron-builder --win --portable"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@libsql/client": "^0.17.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "sqlite3": "^6.0.1",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/sqlite3": "^3.1.11",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.schoolmanagement.app",
    "productName": "School Management System",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "portable"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json"
    ]
  }
}
